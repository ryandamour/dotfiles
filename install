#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------------
# Silverblue bootstrapper:
#  - Reads dependencies from a YAML-style file (or simple list)
#  - Layers them via rpm-ostree only if missing
#  - Copies dotfiles idempotently with rsync
#  - Optionally sets login shell to zsh if installed
#
# Usage:
#   ./install [-d deps.yaml] [-s /path/to/dotfiles] [--no-zsh-chsh] [--dry-run]
#
# Examples:
#   ./install
#   ./install -d deps.yaml -s ./dotfiles
#   ./install -s ~/dotfiles --dry-run
#   ./install --laptop --ohmyzsh --p10k
#
# Notes:
#  - rpm-ostree will stage a new deployment if needed; you'll need to reboot.
#  - Idempotency: already-installed packages are skipped; rsync updates only changes.
# -----------------------------------------------------------------------------

# --- Source library modules ---------------------------------------------------
LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/lib" && pwd)"
export LIB_DIR

source "$LIB_DIR/core.sh"
source "$LIB_DIR/detect.sh"
source "$LIB_DIR/parse.sh"
source "$LIB_DIR/packages.sh"
source "$LIB_DIR/flatpaks.sh"
source "$LIB_DIR/dotfiles.sh"
source "$LIB_DIR/zsh.sh"
source "$LIB_DIR/extras.sh"

# --- Defaults -----------------------------------------------------------------
DEPS_FILE="deps.yaml"
DOTFILES_SRC="./dotfiles"
DO_CHSH=true
DRY_RUN=false
LAPTOP=false
LAPTOP_DEPS_FILE="deps.laptop.yaml"
INSTALL_P10K=false
P10K_DIR="${HOME}/.local/share/powerlevel10k"
P10K_REPO="https://github.com/romkatv/powerlevel10k.git"
P10K_CONFIG_SRC=""
FORCE_P10K=false
INSTALL_OHMYZSH=false
OHMYZSH_DIR="${HOME}/.oh-my-zsh"
OHMYZSH_THEME=""
OHMYZSH_PLUGINS="git,zsh-autosuggestions"
FORCE_OHMYZSH=false
FLATPAK_FILE="flatpak.yaml"
FLATPAK_SCOPE="user"
TERRAFORM_VERSION="1.9.8"

# --- Parse flags --------------------------------------------------------------
while (( "$#" )); do
  case "${1:-}" in
    -d|--deps)          DEPS_FILE="${2:?}"; shift 2 ;;
    -s|--dotfiles)      DOTFILES_SRC="${2:?}"; shift 2 ;;
    --no-zsh-chsh)      DO_CHSH=false; shift ;;
    --p10k)             INSTALL_P10K=true; shift ;;
    --p10k-dir)         P10K_DIR="${2:?}"; shift 2 ;;
    --p10k-config)      P10K_CONFIG_SRC="${2:?}"; shift 2 ;;
    --force-p10k)       FORCE_P10K=true; shift ;;
    --ohmyzsh)          INSTALL_OHMYZSH=true; shift ;;
    --ohmyzsh-dir)      OHMYZSH_DIR="${2:?}"; shift 2 ;;
    --ohmyzsh-theme)    OHMYZSH_THEME="${2:-}"; shift 2 ;;
    --ohmyzsh-plugins)  OHMYZSH_PLUGINS="${2:?}"; shift 2 ;;
    --force-ohmyzsh)    FORCE_OHMYZSH=true; shift ;;
    --laptop)           LAPTOP=true; shift ;;
    --laptop-deps)      LAPTOP_DEPS_FILE="${2:?}"; shift 2 ;;
    --terraform-version) TERRAFORM_VERSION="${2:?}"; shift 2 ;;
    --dry-run)          DRY_RUN=true; shift ;;
    -h|--help)
      sed -n '1,25p' "$0"; exit 0 ;;
    *)
      err "Unknown option: $1"; exit 2 ;;
  esac
done

# --- State file (survives reboot) ---------------------------------------------
STATE_FILE="${HOME}/.dotfiles-state"
PHASE_PACKAGES="packages"
PHASE_CONFIGURE="configure"
PHASE_FINALIZE="finalize"

resume_phase() {
  if [[ -f "$STATE_FILE" ]]; then
    cat "$STATE_FILE"
  else
    echo "$PHASE_PACKAGES"
  fi
}

save_phase() {
  echo "$1" > "$STATE_FILE"
}

# --- Preflight ----------------------------------------------------------------
need_cmd grep
need_cmd awk
need_cmd sed
need_cmd rpm

if ! is_silverblue; then
  warn "This script is tuned for Fedora Silverblue (rpm-ostree). Proceeding anyway."
fi

CURRENT_PHASE="$(resume_phase)"

# --- Phase: packages ----------------------------------------------------------
if [[ "$CURRENT_PHASE" == "$PHASE_PACKAGES" ]]; then
  # --- Flatpaks ---------------------------------------------------------------
  install_flatpaks

  # --- Read & merge deps ------------------------------------------------------
  if [[ ! -f "$DEPS_FILE" ]]; then
    err "Deps file not found: $DEPS_FILE"
    exit 1
  fi

  mapfile -t BASE_DEPS < <(parse_deps "$DEPS_FILE" | awk 'NF')
  if [[ ${#BASE_DEPS[@]} -eq 0 ]]; then
    warn "No dependencies found in $DEPS_FILE."
    BASE_DEPS=()
  fi

  LAPTOP_DEPS=()
  if $LAPTOP; then
    if [[ -f "$LAPTOP_DEPS_FILE" ]]; then
      mapfile -t LAPTOP_DEPS < <(parse_deps "$LAPTOP_DEPS_FILE" | awk 'NF')
      if [[ ${#LAPTOP_DEPS[@]} -eq 0 ]]; then
        warn "Laptop deps file '$LAPTOP_DEPS_FILE' contained no packages."
      else
        log "Including laptop dependencies from '$LAPTOP_DEPS_FILE'."
      fi
    else
      warn "Laptop deps file not found: $LAPTOP_DEPS_FILE (skipping laptop extras)."
    fi
  fi

  ALL_DEPS_RAW=( "${BASE_DEPS[@]}" "${LAPTOP_DEPS[@]}" )
  ALL_DEPS=(); dedupe ALL_DEPS "${ALL_DEPS_RAW[@]}"

  # --- Third-party repos (RPM Fusion, COPR) -----------------------------------
  ensure_repos

  # --- Install packages -------------------------------------------------------
  install_packages "${ALL_DEPS[@]}"

  if ! ${DRY_RUN:-false} && pending_deployment; then
    save_phase "$PHASE_CONFIGURE"
    warn "Reboot required for rpm-ostree deployment. Re-run this script after rebooting."
    exit 100
  fi
else
  log "Resuming after reboot — skipping package installation."
fi

# --- Phase: configure ---------------------------------------------------------
if [[ "$CURRENT_PHASE" == "$PHASE_PACKAGES" || "$CURRENT_PHASE" == "$PHASE_CONFIGURE" ]]; then
  # --- Post-reboot: swap ffmpeg-free for full ffmpeg from RPM Fusion ----------
  if have_pkg rpmfusion-free-release && ! have_pkg ffmpeg; then
    log "Replacing ffmpeg-free with full ffmpeg from RPM Fusion..."
    if ${DRY_RUN:-false}; then
      warn "Dry run: would override ffmpeg-free with ffmpeg"
    else
      maybe_sudo rpm-ostree override remove \
        ffmpeg-free libavcodec-free libavdevice-free libavfilter-free \
        libavformat-free libavutil-free libpostproc-free \
        libswresample-free libswscale-free \
        --install ffmpeg
    fi
  elif have_pkg ffmpeg; then
    log "Full ffmpeg already installed."
  fi

  if ! ${DRY_RUN:-false} && pending_deployment; then
    save_phase "$PHASE_FINALIZE"
    warn "Reboot required for ffmpeg deployment. Re-run this script after rebooting."
    exit 100
  fi
else
  log "Resuming after reboot — skipping ffmpeg override."
fi

# --- Phase: finalize ----------------------------------------------------------
rm -f "$STATE_FILE"

# --- Dotfiles -----------------------------------------------------------------
sync_dotfiles

# --- Oh My Zsh ----------------------------------------------------------------
if $INSTALL_OHMYZSH; then
  # If p10k is requested, tell ohmyzsh to set up the theme now (before p10k dir exists)
  if $INSTALL_P10K && [[ -z "$OHMYZSH_THEME" ]]; then
    OHMYZSH_THEME="powerlevel10k/powerlevel10k"
  fi
  bootstrap_ohmyzsh
else
  log "Oh My Zsh install not requested. Use --ohmyzsh to enable."
fi

# --- Powerlevel10k ------------------------------------------------------------
if $INSTALL_P10K; then
  bootstrap_powerlevel10k
else
  log "Powerlevel10k install not requested. Use --p10k to enable."
fi

# --- Shell & extras -----------------------------------------------------------
set_shell_zsh
install_vscode_flatpak_integration
install_fonts
bootstrap_rofi
install_user_bins

log "Bootstrap complete."
